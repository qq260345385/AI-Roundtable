# AI Roundtable is still an internal alpha / pre-release.
# Mock mode does not call any external API and does not require API keys.
AI_ROUNDTABLE_MODE=mock

# Optional Tavily web search for Web Evidence Pack.
# Keep the real key only in .env.local. Do not commit it.
# When configured, the server can call Tavily once, normalize search results as
# S1-S10 evidence, and share the same evidence pack with every participant model.
TAVILY_API_KEY=
# Optional tuning:
# TAVILY_MAX_RESULTS=20
# TAVILY_SEARCH_DEPTH=basic
# TAVILY_TOPIC=general

# Real mode uses OpenAI-compatible providers configured on the server.
# Copy this file to .env.local before adding real API keys.
# Never put real API keys in .env.example.
#
# If a provider is fully configured but GET {BASE_URL}/models is not compatible
# or times out, AI Roundtable may still try to call it as configured_unverified.
# That status means "检测失败 / 未验证", not "已连接".

# Recommended generic OpenAI-compatible provider configuration:
#
# AI_ROUNDTABLE_MODE=real
# AI_ROUNDTABLE_PROVIDER_IDS=openai,deepseek,qwen,siliconflow
#
# For each provider id, uppercase the id and use:
# AI_ROUNDTABLE_PROVIDER_<ID>_NAME
# AI_ROUNDTABLE_PROVIDER_<ID>_BASE_URL
# AI_ROUNDTABLE_PROVIDER_<ID>_API_KEY
# AI_ROUNDTABLE_PROVIDER_<ID>_MODEL
#
# Optional capability declaration. The system does not guess arbitrary model
# document/image support from model names. If you know a provider's capability,
# declare it explicitly:
#
# AI_ROUNDTABLE_PROVIDER_<ID>_CAPABILITIES=documents,images,native_files
# AI_ROUNDTABLE_PROVIDER_<ID>_SUPPORTS_DOCUMENTS=true
# AI_ROUNDTABLE_PROVIDER_<ID>_SUPPORTS_IMAGES=false
# AI_ROUNDTABLE_PROVIDER_<ID>_SUPPORTS_NATIVE_FILES=false
#
# CAPABILITIES only marks listed capabilities as supported. Missing capabilities
# stay "unknown" unless SUPPORTS_* is set to true or false.

AI_ROUNDTABLE_PROVIDER_IDS=openai,deepseek,qwen

AI_ROUNDTABLE_PROVIDER_OPENAI_NAME=OpenAI
AI_ROUNDTABLE_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
AI_ROUNDTABLE_PROVIDER_OPENAI_API_KEY=
AI_ROUNDTABLE_PROVIDER_OPENAI_MODEL=

AI_ROUNDTABLE_PROVIDER_DEEPSEEK_NAME=DeepSeek
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_API_KEY=
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_MODEL=
# Example: DeepSeek V4 models may support document recognition in the provider
# product, while image recognition can remain unsupported. Keep native files
# false unless this project's adapter can actually send raw file attachments.
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_CAPABILITIES=documents
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_SUPPORTS_IMAGES=false
AI_ROUNDTABLE_PROVIDER_DEEPSEEK_SUPPORTS_NATIVE_FILES=false

AI_ROUNDTABLE_PROVIDER_QWEN_NAME=Qwen
AI_ROUNDTABLE_PROVIDER_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_ROUNDTABLE_PROVIDER_QWEN_API_KEY=
AI_ROUNDTABLE_PROVIDER_QWEN_MODEL=

# Example for another OpenAI-compatible provider:
#
# AI_ROUNDTABLE_PROVIDER_IDS=openai,deepseek,qwen,siliconflow
# AI_ROUNDTABLE_PROVIDER_SILICONFLOW_NAME=SiliconFlow
# AI_ROUNDTABLE_PROVIDER_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# AI_ROUNDTABLE_PROVIDER_SILICONFLOW_API_KEY=
# AI_ROUNDTABLE_PROVIDER_SILICONFLOW_MODEL=

# Legacy compatibility is still supported for now:
#
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=
#
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=
#
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=
